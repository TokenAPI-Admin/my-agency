[Unit]
Description=Commerce AI Workflow UI (FastAPI)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/video-shopping/workflow_ui
EnvironmentFile=/etc/video-shopping/workflow-ui.env
ExecStart=/usr/bin/python3 -m uvicorn app:app --host 0.0.0.0 --port 8600
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

